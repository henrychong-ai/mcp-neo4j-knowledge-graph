# mcp-neo4j-knowledge-graph — example environment
# Copy to .env and fill in:  cp example.env .env
# Full reference: README.md "Embeddings & Reranking Setup" + "Configuration"

# ── Neo4j connection ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j            # NOTE: NEO4J_USERNAME — "NEO4J_USER" is silently ignored
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# ── Vector index ─────────────────────────────────────────────────────────────
# THE RULE: NEO4J_VECTOR_DIMENSIONS == EMBEDDING_DIMENSIONS == the embedding
# model's NATIVE output dimension. Mismatched vectors are refused at write time.
NEO4J_VECTOR_INDEX=entity_embeddings
NEO4J_VECTOR_DIMENSIONS=1536
NEO4J_SIMILARITY_FUNCTION=cosine

# ── Embeddings: Option A — OpenAI (default) ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # 1536 dimensions

# ── Embeddings: Option B — Cloudflare Workers AI (free plan suffices) ────────
# Token: CF dashboard → My Profile → API Tokens → "Workers AI" template.
# Remember to change NEO4J_VECTOR_DIMENSIONS to 1024 to match qwen3.
# EMBEDDING_API_KEY=your-cf-workers-ai-token
# EMBEDDING_API_ENDPOINT=https://api.cloudflare.com/client/v4/accounts/<your-account-id>/ai/v1/embeddings
# EMBEDDING_MODEL=@cf/qwen/qwen3-embedding-0.6b   # 1024-dim out; ~8192-token input cap (longer entities truncated head-only)
# EMBEDDING_DIMENSIONS=1024

# ── Embeddings: Option C — any OpenAI-compatible endpoint (Ollama/LM Studio) ─
# EMBEDDING_API_KEY=anything-non-empty
# EMBEDDING_API_BASE_URL=http://localhost:11434/v1   # /embeddings appended automatically
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768

# With NO provider configured the server runs keyword-only (semantic_search
# falls back; random/mock vectors are never generated implicitly).

# ── Optional cross-encoder reranker (v2.5.0+, fail-open) ─────────────────────
# RERANK_ENABLED=true
# RERANK_ACCOUNT_ID=<your-account-id>             # derives the CF endpoint from the model
# RERANK_MODEL=@cf/baai/bge-reranker-base
# RERANK_API_KEY=your-cf-workers-ai-token         # falls back to EMBEDDING_API_KEY
# RERANK_TOP_N=20    # scoring-payload cap (candidates sent to the cross-encoder) — NOT a return count
# RERANK_TOP_K=5     # default return count with a reranker configured (explicit `limit` always wins)
# RERANK_MAX_PASSAGE_CHARS=2000  # per-passage truncation before scoring — bge-reranker-base only
#                                # sees ~512 tokens, so 2000 chars ≈ that window
# RERANK_TIMEOUT_MS=5000         # reranker HTTP timeout; on timeout/error it fails open
# NOTE: min_similarity is a per-call semantic_search tool parameter (not env);
# default 0 (disabled) on Neo4j's (cos+1)/2 normalised score scale.

# ── Oversized-entity flagging (v2.8.0+) ──────────────────────────────────────
# Early warning before an entity outgrows the open_nodes output cap and becomes
# unretrievable. All advisory; sizing is a conservative chars-per-token estimate.
# MAX_MCP_OUTPUT_TOKENS=25000        # assumed open_nodes cap (tokens); match your client if it differs
# ENTITY_SIZE_WARN_RATIO=0.8         # fraction of the cap → WARN
# ENTITY_SIZE_CRITICAL_RATIO=1.0     # fraction of the cap → CRITICAL (>= warn ratio)
# ENTITY_SIZE_WARN_ON_WRITE=true     # write tools append a non-fatal warnings[] when an entity crosses WARN/CRITICAL
# ENTITY_SIZE_SCAN_LIMIT=50          # default number of largest entities scanned per pass
# CLI digest: `pnpm run kg:oversized` (exit 1 if any CRITICAL — schedule weekly alongside the backfill).

# ── Topology (multi-client deployments) ──────────────────────────────────────
# Server-side instance (owns ALL embedding writes): keep the default below and
# tighten the backfill cron. Thin clients (laptops/IDE MCP configs): set
# WRITE_EMBEDDINGS_LOCALLY=false — they embed queries only and can never
# pollute the shared store.
WRITE_EMBEDDINGS_LOCALLY=true
EMBEDDING_BACKFILL_CRON=0 19 * * *
EMBEDDING_STALE_CLAIM_MS=300000

# ── Logging / metrics ────────────────────────────────────────────────────────
LOG_LEVEL=warn
# ENABLE_PROMETHEUS_METRICS=true   # serves /metrics on :9091

# ── Testing only — NEVER in production (refused under NODE_ENV=production) ───
# MOCK_EMBEDDINGS=true
