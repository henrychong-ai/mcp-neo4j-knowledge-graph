{
  "name": "@henrychong-ai/mcp-neo4j-knowledge-graph",
  "version": "2.8.1",
  "description": "Neo4j-based knowledge graph MCP server with temporal versioning and semantic search",
  "license": "MIT",
  "author": "Henry Chong <henry@henrychong.ai>",
  "contributors": [
    "Gannon Hall (original author)"
  ],
  "homepage": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph",
  "bugs": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph/issues",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-neo4j-knowledge-graph": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "neo4j",
    "knowledge-graph",
    "memory",
    "llm",
    "ai",
    "claude"
  ],
  "files": [
    "dist",
    "SETUP_AUTOMATION.md",
    "example.env"
  ],
  "scripts": {
    "build": "tsc && echo '#!/usr/bin/env node' | cat - dist/index.js > dist/index.js.tmp && mv dist/index.js.tmp dist/index.js && shx chmod +x dist/*.js",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "clear && vitest run --reporter verbose",
    "test:integration": "TEST_INTEGRATION=true pnpm test",
    "lint": "oxlint --max-warnings=0",
    "lint:fix": "oxlint --fix --max-warnings=0",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "fix": "pnpm run lint:fix && pnpm run format",
    "neo4j:init": "tsx src/cli/neo4j-setup.ts init",
    "neo4j:test": "tsx src/cli/neo4j-setup.ts test",
    "embeddings:generate": "tsx src/cli/generate-embeddings.ts",
    "embeddings:test": "tsx src/cli/generate-embeddings.ts -- --limit 5",
    "kg:oversized": "tsx src/cli/report-oversized.ts",
    "kg:oversized:json": "tsx src/cli/report-oversized.ts -- --json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "lru-cache": "^11.5.1",
    "neo4j-driver": "^6.1.0",
    "node-cron": "^4.2.1",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.68.0",
    "shx": "^0.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "rollup": ">=4.59.0",
      "ajv": ">=8.18.0",
      "hono": ">=4.12.21",
      "@hono/node-server": ">=1.19.13",
      "express-rate-limit": ">=8.2.2",
      "qs": ">=6.15.2",
      "vite": ">=7.3.5 <8.0.0",
      "picomatch": ">=4.0.4",
      "micromatch>picomatch": "^2.3.2",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "follow-redirects": ">=1.16.0",
      "fast-uri": ">=3.1.2 <4",
      "ip-address": ">=10.1.1",
      "postcss": ">=8.5.10",
      "form-data": ">=4.0.6 <5.0.0",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1 <0.29.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix --max-warnings=0",
      "biome format --write"
    ],
    "*.json": [
      "biome format --write"
    ]
  }
}
