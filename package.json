{
  "name": "@henrychong-ai/mcp-neo4j-knowledge-graph",
  "version": "1.12.2",
  "description": "Neo4j-based knowledge graph MCP server with temporal versioning and semantic search",
  "license": "MIT",
  "author": "Henry Chong <henry@henrychong.ai>",
  "contributors": [
    "Gannon Hall (original author)"
  ],
  "homepage": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph",
  "bugs": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph/issues",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-neo4j-knowledge-graph": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "neo4j",
    "knowledge-graph",
    "memory",
    "llm",
    "ai",
    "claude"
  ],
  "files": [
    "dist",
    "SETUP_AUTOMATION.md"
  ],
  "scripts": {
    "build": "tsc && echo '#!/usr/bin/env node' | cat - dist/index.js > dist/index.js.tmp && mv dist/index.js.tmp dist/index.js && shx chmod +x dist/*.js",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "clear && vitest run --reporter verbose",
    "test:integration": "TEST_INTEGRATION=true pnpm test",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "fix": "pnpm run lint:fix && pnpm run format",
    "neo4j:init": "tsx src/cli/neo4j-setup.ts init",
    "neo4j:test": "tsx src/cli/neo4j-setup.ts test",
    "embeddings:generate": "tsx src/cli/generate-embeddings.ts",
    "embeddings:test": "tsx src/cli/generate-embeddings.ts -- --limit 5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "hono": "^4.11.4",
    "lru-cache": "^11.1.0",
    "neo4j-driver": "^6.0.0",
    "node-cron": "^3.0.3",
    "openai": "^6.7.0",
    "prom-client": "^15.1.3",
    "ts-node": "^10.9.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.7.0",
    "@types/node": "^24",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "glob": "^11.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "semver": "^7.6.0",
    "shx": "^0.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.0",
    "zod": "^3.24.2"
  },
  "overrides": {
    "glob": "^11.0.1",
    "rimraf": "^6.0.1",
    "hono": "^4.11.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
