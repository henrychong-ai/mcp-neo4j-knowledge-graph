{
  "name": "@henrychong-ai/mcp-neo4j-knowledge-graph",
  "version": "2.2.2",
  "description": "Neo4j-based knowledge graph MCP server with temporal versioning and semantic search",
  "license": "MIT",
  "author": "Henry Chong <henry@henrychong.ai>",
  "contributors": [
    "Gannon Hall (original author)"
  ],
  "homepage": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph",
  "bugs": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph/issues",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-neo4j-knowledge-graph": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/henrychong-ai/mcp-neo4j-knowledge-graph.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "neo4j",
    "knowledge-graph",
    "memory",
    "llm",
    "ai",
    "claude"
  ],
  "files": [
    "dist",
    "SETUP_AUTOMATION.md"
  ],
  "scripts": {
    "build": "tsc && echo '#!/usr/bin/env node' | cat - dist/index.js > dist/index.js.tmp && mv dist/index.js.tmp dist/index.js && shx chmod +x dist/*.js",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "clear && vitest run --reporter verbose",
    "test:integration": "TEST_INTEGRATION=true pnpm test",
    "lint": "oxlint --max-warnings=0",
    "lint:fix": "oxlint --fix --max-warnings=0",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "fix": "pnpm run lint:fix && pnpm run format",
    "neo4j:init": "tsx src/cli/neo4j-setup.ts init",
    "neo4j:test": "tsx src/cli/neo4j-setup.ts test",
    "embeddings:generate": "tsx src/cli/generate-embeddings.ts",
    "embeddings:test": "tsx src/cli/generate-embeddings.ts -- --limit 5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "lru-cache": "^11.2.6",
    "neo4j-driver": "^6.0.1",
    "node-cron": "^4.2.1",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/node": "^24.10.9",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxlint": "^1.48.0",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "rollup": ">=4.59.0",
      "ajv": ">=8.18.0",
      "hono": ">=4.11.10",
      "qs": ">=6.14.2"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix --max-warnings=0",
      "biome format --write"
    ],
    "*.json": [
      "biome format --write"
    ]
  }
}
