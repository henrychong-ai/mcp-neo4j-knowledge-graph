# Neo4j Database Connection
# These environment variables configure the connection to your Neo4j database.
# The dashboard connects directly to Neo4j (same database used by the MCP server).

# Neo4j connection URI
# Format: bolt://hostname:port or neo4j://hostname:port
# Default: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687

# Neo4j username
# Default: neo4j
NEO4J_USERNAME=neo4j

# Neo4j password
# Set this to your Neo4j database password
NEO4J_PASSWORD=your_password_here

# Neo4j database name (optional)
# Default: neo4j
# Uncomment if you're using a different database name
# NEO4J_DATABASE=neo4j

# Next.js Configuration (optional)

# Port for the development server (optional)
# Default: 3000
# PORT=3000

# Node environment
# Default: development
# NODE_ENV=development

# Notes:
# - Copy this file to .env.local and fill in your actual values
# - .env.local is gitignored and should never be committed
# - The dashboard uses the same Neo4j database as the MCP server
# - Ensure your Neo4j instance is running before starting the dashboard
